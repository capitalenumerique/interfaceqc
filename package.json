{
  "name": "interfaceqc",
  "private": true,
  "type": "module",
  "scripts": {
    "get-git-env": "NUXT_ENV_CURRENT_GIT_SHA=`git rev-parse --short HEAD` NUXT_ENV_CURRENT_GIT_TAG=`git describe --tags $(git rev-list --tags --max-count=1)`",
    "build": "pnpm run get-git-env nuxt build",
    "dev": "concurrently \"pnpm:nuxt:dev\" \"pnpm:slicemachine\" --names \"nuxt,slicemachine\" --prefix-colors green,magenta",
    "nuxt:dev": "pnpm run get-git-env nuxt dev",
    "generate": "pnpm run get-git-env nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "slicemachine": "start-slicemachine"
  },
  "dependencies": {
    "@limonische/vue3-transition-expand": "^2.0.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/scripts": "^0.13.2",
    "@peterbud/nuxt-query": "^1.6.0",
    "@prismicio/client": "^7.21.6",
    "@tanstack/vue-query": "^5.92.12",
    "@unhead/vue": "^2.1.12",
    "canvas-confetti": "^1.9.4",
    "es-toolkit": "^1.45.1",
    "focus-trap": "^8.0.0",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "luxon": "^3.7.2",
    "normalize.css": "^8.0.1",
    "nuxt": "^4.4.2",
    "swiper": "^12.1.2",
    "vue": "^3.5.30",
    "vue-draggable-plus": "^0.6.1",
    "vue3-marquee": "^4.2.2"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@nuxtjs/prismic": "^5.2.0",
    "@prismicio/vue": "^6.1.1",
    "@slicemachine/adapter-nuxt": "^0.3.95",
    "@types/canvas-confetti": "^1.9.0",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/luxon": "^3.7.1",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "@vueuse/nuxt": "^14.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "postcss": "^8.5.8",
    "postcss-functions": "^4.0.2",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.0",
    "slice-machine-ui": "^2.21.1",
    "typescript": "^5.9.3",
    "vite-plugin-eslint2": "^5.0.5",
    "vite-svg-loader": "^5.1.1",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.19.0"
}
